generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



enum UserStatus {

  ACTIVE

  INVITED

  SUSPENDED

  DISABLED

}



enum QuestionType {

  MCQ

  CODING

}



enum QuestionStatus {

  DRAFT

  REVIEW

  PUBLISHED

  ARCHIVED

}



enum ExamStatus {

  DRAFT

  SCHEDULED

  ACTIVE

  ENDED

  ARCHIVED

}



enum SessionStatus {

  CREATED

  IN_PROGRESS

  PAUSED

  SUBMITTED

  AUTO_SUBMITTED

  EVALUATED

  INVALIDATED

}



enum EnrollmentStatus {

  ACTIVE

  COMPLETED

  DROPPED

  SUSPENDED

}



enum NotificationType {

  SYSTEM

  EXAM

  RESULT

  CERTIFICATE

  SECURITY

}



enum CertificateStatus {

  ISSUED

  REVOKED

  EXPIRED

}



model User {

  id             String   @id @default(uuid()) @db.Uuid

  email          String   @unique

  passwordHash    String

  fullName        String

  phone           String?  @unique

  status          UserStatus @default(ACTIVE)

  emailVerifiedAt DateTime?

  lastLoginAt     DateTime?

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt



  studentProfile              StudentProfile?

  facultyProfile              FacultyProfile?

  userRoles                   UserRole[]

  createdCourses              Course[] @relation("CourseCreatedBy")

  createdQuestions             Question[] @relation("QuestionCreatedBy")

  createdExams                 Exam[] @relation("ExamCreatedBy")

  evaluatedResults            Result[] @relation("ResultEvaluatedBy")

  issuedCertificates          Certificate[] @relation("CertificateIssuedBy")

  notifications               Notification[]

  auditLogs                   AuditLog[] @relation("AuditActor")

  refreshTokens               RefreshToken[]

  courseInstructorAssignments  CourseInstructor[] @relation("CourseInstructorAssignedBy")

  enrollmentActions           Enrollment[] @relation("EnrollmentEnrolledBy")

  userRoleAssignments         UserRole[] @relation("UserRoleAssignedBy")

  updatedSettings             SystemSetting[] @relation("SettingUpdatedBy")

  codeRuns                    CodeRun[]
  examSessions                ExamSession[] @relation("SessionUser")

}



model StudentProfile {

  userId          String   @id @db.Uuid

  departmentId    String?  @db.Uuid

  studentNumber   String   @unique

  admissionYear   Int

  currentSemester Int

  gpa             Decimal?

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt



  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  department    Department? @relation("DepartmentStudents", fields: [departmentId], references: [id], onDelete: SetNull)

  enrollments   Enrollment[]

}



model FacultyProfile {

  userId         String   @id @db.Uuid

  departmentId   String   @db.Uuid

  employeeNumber String   @unique

  designation    String

  specialization String?

  hireDate       DateTime?

  createdAt      DateTime @default(now())

  updatedAt      DateTime @updatedAt



  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  department      Department @relation("DepartmentFaculty", fields: [departmentId], references: [id], onDelete: Restrict)

  courseAssignments CourseInstructor[]

}



model Department {

  id          String   @id @default(uuid()) @db.Uuid

  code        String   @unique

  name        String   @unique

  description String?

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt



  students    StudentProfile[] @relation("DepartmentStudents")

  faculty     FacultyProfile[] @relation("DepartmentFaculty")

  courses     Course[] @relation("DepartmentCourses")

  questions   Question[] @relation("DepartmentQuestions")

}



model Course {

  id            String   @id @default(uuid()) @db.Uuid

  departmentId  String   @db.Uuid

  createdByUserId String? @db.Uuid

  code          String

  title         String

  description   String?

  credits       Int

  level         Int?

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())

  updatedAt     DateTime @updatedAt



  department   Department @relation("DepartmentCourses", fields: [departmentId], references: [id], onDelete: Restrict)

  createdBy    User?      @relation("CourseCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  instructors  CourseInstructor[]

  enrollments  Enrollment[]

  exams        Exam[]



  @@unique([departmentId, code])

  @@index([departmentId])

  @@index([createdByUserId])

}



model CourseInstructor {

  courseId        String   @db.Uuid

  facultyUserId   String   @db.Uuid

  assignedAt      DateTime @default(now())

  assignedByUserId String? @db.Uuid



  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  faculty     FacultyProfile @relation(fields: [facultyUserId], references: [userId], onDelete: Cascade)

  assignedBy  User?          @relation("CourseInstructorAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)



  @@id([courseId, facultyUserId])

  @@index([facultyUserId])

}



model Enrollment {

  courseId          String           @db.Uuid

  studentUserId     String           @db.Uuid

  enrolledAt        DateTime         @default(now())

  status            EnrollmentStatus @default(ACTIVE)

  enrolledByUserId   String?          @db.Uuid



  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)

  student     StudentProfile @relation(fields: [studentUserId], references: [userId], onDelete: Cascade)

  enrolledBy  User?       @relation("EnrollmentEnrolledBy", fields: [enrolledByUserId], references: [id], onDelete: SetNull)



  @@id([courseId, studentUserId])

  @@index([studentUserId])

  @@index([status])

}



model Role {

  id          String   @id @default(uuid()) @db.Uuid

  key         String   @unique

  name        String   @unique

  description String?

  isSystem    Boolean  @default(false)

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt



  userRoles     UserRole[]

  permissions   RolePermission[]

}



model Permission {

  id          String   @id @default(uuid()) @db.Uuid

  key         String   @unique

  name        String   @unique

  description String?

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt



  rolePermissions RolePermission[]

}



model UserRole {

  userId           String   @db.Uuid

  roleId           String   @db.Uuid

  assignedAt       DateTime @default(now())

  assignedByUserId String?  @db.Uuid



  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role        Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedBy  User?  @relation("UserRoleAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)



  @@id([userId, roleId])

  @@index([roleId])

}



model RolePermission {

  roleId       String @db.Uuid

  permissionId String @db.Uuid



  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)



  @@id([roleId, permissionId])

  @@index([permissionId])

}



model Question {

  id               String        @id @default(uuid()) @db.Uuid

  departmentId     String        @db.Uuid

  createdByUserId   String?       @db.Uuid

  type             QuestionType

  status           QuestionStatus @default(DRAFT)

  title            String

  prompt           String

  explanation      String?

  difficulty       Int

  marks            Int

  timeLimitSeconds Int?

  tags             Json?

  metadata         Json?

  createdAt        DateTime      @default(now())

  updatedAt        DateTime      @updatedAt



  department    Department      @relation("DepartmentQuestions", fields: [departmentId], references: [id], onDelete: Restrict)

  createdBy     User?           @relation("QuestionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  mcq           McqQuestion?

  coding        CodingQuestion?

  examQuestions  ExamQuestion[]

  answers        StudentAnswer[]

  codeRuns       CodeRun[]



  @@index([departmentId])

  @@index([type, status])

  @@index([difficulty])

}



model McqQuestion {

  questionId          String   @id @db.Uuid

  options             Json

  correctOptionIndex  Int

  shuffleOptions      Boolean  @default(true)

  answerExplanation   String?



  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

}



model CodingQuestion {

  questionId            String   @id @db.Uuid

  starterCode           String?

  solutionTemplate      String?

  testCases             Json

  languageConstraints   Json?

  sampleInput           String?

  sampleOutput          String?



  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

}



model Exam {

  id                String      @id @default(uuid()) @db.Uuid

  courseId          String      @db.Uuid

  createdByUserId   String?     @db.Uuid

  title             String

  instructions      String?

  durationMinutes   Int

  totalMarks        Int

  passMarks         Int

  status            ExamStatus  @default(DRAFT)

  startsAt          DateTime?

  endsAt            DateTime?

  randomizeQuestions Boolean     @default(true)

  allowReview       Boolean     @default(false)

  attemptLimit      Int         @default(1)

  publishedAt       DateTime?

  createdAt         DateTime    @default(now())

  updatedAt         DateTime    @updatedAt



  course      Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdBy   User?         @relation("ExamCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  questions   ExamQuestion[]

  sessions    ExamSession[]



  @@index([courseId])

  @@index([status, startsAt])

}



model ExamQuestion {

  examId           String @db.Uuid

  questionId       String @db.Uuid

  sequenceNo       Int

  marksOverride    Int?

  negativeMarks    Int    @default(0)

  isMandatory      Boolean @default(true)

  questionSnapshot Json?

  scoringSnapshot  Json?



  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  question Question @relation(fields: [questionId], references: [id], onDelete: Restrict)



  @@id([examId, questionId])

  @@unique([examId, sequenceNo])

  @@index([questionId])

}



model ExamSession {

  id                String        @id @default(uuid()) @db.Uuid

  examId            String        @db.Uuid

  studentUserId     String        @db.Uuid

  attemptNo         Int           @default(1)

  status            SessionStatus @default(CREATED)

  startedAt         DateTime?

  submittedAt       DateTime?

  autoSubmittedAt   DateTime?

  evaluatedAt       DateTime?

  expiresAt         DateTime?

  lockedAt          DateTime?

  ipAddress         String?

  userAgent         String?

  createdAt         DateTime      @default(now())

  updatedAt         DateTime      @updatedAt



  exam      Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)

  user   User @relation("SessionUser", fields: [studentUserId], references: [id], onDelete: Cascade)

  answers   StudentAnswer[]

  result    Result?

  codeRuns  CodeRun[]



  @@unique([examId, studentUserId, attemptNo])

  @@index([examId, studentUserId])

  @@index([status, startedAt])

}



model StudentAnswer {

  id               String   @id @default(uuid()) @db.Uuid

  sessionId        String   @db.Uuid

  questionId       String   @db.Uuid

  answerText       String?

  selectedOptionIndex Int?

  codeAnswer       String?

  answerPayload    Json?

  isCorrect        Boolean?

  marksAwarded     Int?

  submittedAt      DateTime @default(now())

  createdAt        DateTime @default(now())

  updatedAt        DateTime @updatedAt



  session    ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  question   Question    @relation(fields: [questionId], references: [id], onDelete: Restrict)



  @@unique([sessionId, questionId])

  @@index([questionId])

}



model Result {

  id               String   @id @default(uuid()) @db.Uuid

  sessionId        String   @unique @db.Uuid

  evaluatedByUserId String?  @db.Uuid

  obtainedMarks    Int

  maxMarks         Int

  percentage       Decimal

  passed           Boolean

  grade            String?

  remarks          String?

  breakdown        Json?

  evaluatedAt      DateTime @default(now())

  createdAt        DateTime @default(now())

  updatedAt        DateTime @updatedAt



  session      ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  evaluatedBy  User?       @relation("ResultEvaluatedBy", fields: [evaluatedByUserId], references: [id], onDelete: SetNull)

  certificate  Certificate?



  @@index([passed, percentage])

}



model Certificate {

  id                String            @id @default(uuid()) @db.Uuid

  resultId          String            @unique @db.Uuid

  certificateNumber String            @unique

  verificationCode  String            @unique

  issuedAt          DateTime          @default(now())

  status            CertificateStatus @default(ISSUED)

  pdfUrl            String?

  issuerUserId      String?           @db.Uuid



  result    Result @relation(fields: [resultId], references: [id], onDelete: Cascade)

  issuedBy  User?  @relation("CertificateIssuedBy", fields: [issuerUserId], references: [id], onDelete: SetNull)



  @@index([status, issuedAt])

}



model Notification {

  id         String           @id @default(uuid()) @db.Uuid

  userId     String           @db.Uuid

  type       NotificationType

  title      String

  body       String

  data       Json?

  readAt     DateTime?

  sentAt     DateTime?

  createdAt  DateTime         @default(now())

  updatedAt  DateTime         @updatedAt



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([userId, readAt])

  @@index([type, createdAt])

}



model AuditLog {

  id           String   @id @default(uuid()) @db.Uuid

  actorUserId  String?  @db.Uuid

  action       String

  entityType   String

  entityId     String?

  metadata     Json?

  ipAddress    String?

  userAgent    String?

  createdAt    DateTime @default(now())



  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)



  @@index([actorUserId, createdAt])

  @@index([entityType, entityId])

}



model RefreshToken {

  id               String   @id @default(uuid()) @db.Uuid

  userId           String   @db.Uuid

  tokenHash        String   @unique

  deviceId         String?

  familyId         String?

  expiresAt        DateTime

  revokedAt        DateTime?

  lastUsedAt       DateTime?

  rotatedFromTokenId String? @db.Uuid

  createdAt        DateTime @default(now())

  updatedAt        DateTime @updatedAt



  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  rotatedFrom RefreshToken? @relation("RefreshTokenRotation", fields: [rotatedFromTokenId], references: [id], onDelete: SetNull)

  rotatedTo   RefreshToken[] @relation("RefreshTokenRotation")



  @@index([userId, expiresAt])

  @@index([revokedAt])

}



model SystemSetting {

  id               String   @id @default(uuid()) @db.Uuid

  category         String

  key              String

  value            Json     @db.JsonB

  description      String?

  updatedByUserId  String?  @db.Uuid

  createdAt        DateTime @default(now())

  updatedAt        DateTime @updatedAt



  updatedBy User? @relation("SettingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)



  @@unique([category, key])

  @@index([category])

}



model CodeRun {

  id              String       @id @default(uuid()) @db.Uuid

  userId          String       @db.Uuid

  sessionId       String?      @db.Uuid

  questionId      String?      @db.Uuid

  language        String

  sourceCode      String

  stdin           String?

  stdout          String?

  stderr          String?

  status          CodeRunStatus @default(PENDING)

  executionTimeMs Int?

  createdAt       DateTime     @default(now())



  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  session  ExamSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  question Question?    @relation(fields: [questionId], references: [id], onDelete: SetNull)



  @@index([userId, createdAt])

  @@index([sessionId])

  @@index([status, createdAt])

}



enum CodeRunStatus {

  PENDING

  RUNNING

  COMPLETED

  FAILED

  TIMEOUT

}